{
    "name": "chancegarcia/php-box-sdk",
    "license": "Apache-2.0",
    "description": "PHP SDK and API client for the Box API v2024.0, supporting OAuth2 and JWT/S2S authentication, file and folder operations, uploads, webhook signature verification, typed models, and PSR-3 logging.",
    "keywords": [
        "box",
        "box-api",
        "box-api-v2024",
        "box-sdk",
        "box-v2",
        "box-platform",
        "cloud-storage",
        "file-storage",
        "file-upload",
        "oauth2",
        "jwt",
        "webhook",
        "php-sdk",
        "sdk",
        "api-client",
        "psr-3",
        "guzzle"
    ],
    "homepage": "https://github.com/chancegarcia/php-box-sdk",
    "support": {
        "docs": "https://developer.box.com/reference",
        "source": "https://github.com/chancegarcia/php-box-sdk",
        "issues": "https://github.com/chancegarcia/php-box-sdk/issues"
    },
    "autoload": {
        "psr-4": {
            "Box\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Box\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "psr/log": "^3",
        "psr/event-dispatcher": "^1.0",
        "ext-fileinfo": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "symfony/dotenv": "^7.4|^8",
        "symfony/console": "^7.4|^8",
        "monolog/monolog": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "psr/http-message": "^2.0",
        "guzzlehttp/psr7": "^2.0",
        "doctrine/collections": "^2.2"
    },
    "authors": [
        {
            "name": "chance garcia",
            "email": "develop@chancegarcia.com"
        }
    ],
    "require-dev": {
        "roave/security-advisories": "dev-latest"
        ,
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "slevomat/coding-standard": "^8.29"
    },
    "scripts": {
        "cs:check": "phpcs",
        "cs:fix": "phpcbf",
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-html build/coverage",
        "lint": "find src tests bin -name '*.php' -print0 | xargs -0 -n 1 -P 8 php -l",
        "analyse": "phpstan analyse --memory-limit=2G",
        "analyze": "@analyse",
        "stan": "@analyse",
        "review": [
            "@lint",
            "@cs:check",
            "@analyse",
            "@test"
        ],
        "qa": "@review"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
