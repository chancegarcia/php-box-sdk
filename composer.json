{
    "name": "chancegarcia/box-api-v2-sdk",
    "license": "MIT",
    "description": "PHP SDK and API client for Box API workflows compatible with Box API v2024.0, including OAuth2 authentication, file and folder operations, uploads, typed models, PSR-3 logging, and pluggable HTTP transports.",
    "keywords": [
        "box",
        "box-api",
        "box-api-v2024",
        "box-sdk",
        "box-v2",
        "box-platform",
        "cloud-storage",
        "file-storage",
        "file-upload",
        "oauth2",
        "php-sdk",
        "sdk",
        "api-client",
        "psr-3",
        "guzzle"
    ],
    "homepage": "https://github.com/chancegarcia/box.net-v2api-sdk",
    "support": {
        "docs": "https://developer.box.com/reference",
        "source": "https://github.com/chancegarcia/box.net-v2api-sdk",
        "issues": "https://github.com/chancegarcia/box.net-v2api-sdk/issues"
    },
    "autoload": {
        "psr-4": {
            "Box\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Box\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "symfony/http-foundation": "^7.4|^8",
        "psr/log": "^3",
        "ext-curl": "*",
        "ext-fileinfo": "*",
        "symfony/dotenv": "^7.4",
        "symfony/console": "^7.4",
        "monolog/monolog": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "psr/http-message": "^2.0",
        "guzzlehttp/psr7": "^2.0",
        "doctrine/collections": "^2.2"
    },
    "authors": [
        {
            "name": "chance garcia",
            "email": "develop@chancegarcia.com"
        }
    ],
    "require-dev": {
        "roave/security-advisories": "dev-latest"
        ,
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "cs:check": "phpcs",
        "cs:fix": "phpcbf",
        "test": "phpunit",
        "lint": "find src tests bin -name '*.php' -print0 | xargs -0 -n 1 -P 8 php -l",
        "analyse": "phpstan analyse --memory-limit=2G",
        "analyze": "@analyse",
        "review": [
            "@lint",
            "@cs:check",
            "@analyse",
            "@test"
        ]
    }
}
