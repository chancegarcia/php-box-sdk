#!/usr/bin/env php
<?php

require __DIR__.'/../vendor/autoload.php';

use Box\Command\AuthExchangeCommand;
use Box\Command\AuthRefreshCommand;
use Box\Command\AuthUrlCommand;
use Box\Command\FileUploadCommand;
use Box\Command\JwtTokenCommand;
use Box\Contract\JsonFormatterInterface;
use Box\Factory\BoxClientFactory;
use Box\Logger\ConfigNormalizer;
use Box\Logger\LoggerFactory;
use Box\Service\ConsoleOutputFormatter;
use Box\Service\DefaultJsonFormatter;
use Box\Service\EnvConfigProvider;
use Symfony\Component\Console\Application;
use Symfony\Component\Dotenv\Dotenv;

$dotenv = new Dotenv();
if (file_exists(__DIR__ . '/../.env')) {
    $dotenv->load(__DIR__ . '/../.env');
}

$application = new Application('Box SDK CLI', '1.0.0');

$configProvider = new EnvConfigProvider();
$clientFactory = new BoxClientFactory($configProvider);

// Resolve JSON formatter
$jsonFormatterClass = $configProvider->getJsonFormatterClass() ?? DefaultJsonFormatter::class;
if (!class_exists($jsonFormatterClass)) {
    throw new \RuntimeException(sprintf('JSON formatter class "%s" not found.', $jsonFormatterClass));
}
$jsonFormatter = new $jsonFormatterClass();
if (!$jsonFormatter instanceof JsonFormatterInterface) {
    throw new \RuntimeException(sprintf('JSON formatter class "%s" must implement Box\Contract\JsonFormatterInterface.', $jsonFormatterClass));
}

$outputFormatter = new ConsoleOutputFormatter($jsonFormatter);

$configNormalizer = new ConfigNormalizer();
$loggerFactory = new LoggerFactory($configNormalizer);

$application->addCommand(new AuthUrlCommand($clientFactory, $configProvider, $outputFormatter, $loggerFactory));
$application->addCommand(new AuthExchangeCommand($clientFactory, $configProvider, $outputFormatter, $loggerFactory));
$application->addCommand(new AuthRefreshCommand($clientFactory, $configProvider, $outputFormatter, $loggerFactory));
$application->addCommand(new JwtTokenCommand($clientFactory, $configProvider, $outputFormatter, $loggerFactory));
$application->addCommand(new FileUploadCommand($clientFactory, $configProvider, $outputFormatter, $loggerFactory));

$application->run();